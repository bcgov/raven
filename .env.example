# RAVEN Configuration — copy to ~/.raven/.env
# See README.md for setup instructions.

# Atlassian Data Center (Basic Auth)
ATLASSIAN_BASE_URL=<base url including https>
ATLASSIAN_EMAIL=<your gov.bc.ca email>
ATLASSIAN_PASSWORD=<your IDIR password>

# JFrog Artifactory through the HTTPS BWA endpoint (dedicated variables;
# Raven does not implicitly reuse ATLASSIAN_* credentials)
ARTIFACTORY_URL=<internal Artifactory HTTPS base URL; ask the RAVEN maintainer>
ARTIFACTORY_EMAIL=<your gov.bc.ca email>
ARTIFACTORY_PASSWORD=<your IDIR password>
# Protected transfer directories must be chmod 700; upload files must be chmod 600.
# RAVEN_ARTIFACTORY_UPLOAD_DIR=~/.raven/artifactory-uploads
# RAVEN_ARTIFACTORY_DOWNLOAD_DIR=~/.raven/artifactory-downloads
# RAVEN_ARTIFACTORY_MAX_TRANSFER_BYTES=536870912
# RAVEN_ARTIFACTORY_DOWNLOAD_TIMEOUT_MS=1800000
# Comma-separated exact HTTPS hostnames approved for direct cloud-storage downloads.
# RAVEN_ARTIFACTORY_DOWNLOAD_REDIRECT_HOSTS=storage.example.gov.bc.ca

# PI Scrubbing — anonymize names before they reach the LLM (FOIPPA)
RAVEN_SCRUB_PI=true

# Optional Jira customfield IDs. Defaults match BC Gov NRM Jira; override
# only if your instance uses different IDs for Epic Link / Epic Name.
# JIRA_EPIC_LINK_FIELD=customfield_10006
# JIRA_EPIC_NAME_FIELD=customfield_10005

# Server Monitoring Tools (server-mcp, server-ui)
# SSH password for your _A account (ssh_user is set per-server in ~/bin/servers.conf)
# See servers.conf.example for the servers.conf format.
SERVER_A_PASSWORD=<your _A account password>

# Override the directory where servers.conf is read from (default: ~/bin/)
# SERVER_TOOLS_BIN=/path/to/dir

# Optional: SSH key-based authentication (per-host opt-in)
# Default is password auth via SERVER_A_PASSWORD. To use key auth on
# specific hosts, set BOTH variables below: SSH_KEY_PATH points to your
# private key, and SSH_KEY_HOSTS lists the hosts where your public key is
# in ~/.ssh/authorized_keys. Hosts not in the list use password auth.
# This avoids any failed-publickey log entries on hosts where your key is
# not authorized. SERVER_A_PASSWORD is needed for password auth on hosts
# not in SSH_KEY_HOSTS and for sudo on the remote server — keep it set
# unless you key-auth every host AND never sudo.
# SSH_KEY_PATH=/Users/<you>/.ssh/id_ed25519
# SSH_KEY_HOSTS=int01,test01,prod01
# Use SSH_KEY_HOSTS=* to use the key on every host (strict; will fail if
# the key is not authorized on any given host — no password fallback).

# Required only if SSH_KEY_PATH points to a passphrase-protected key.
# SSH_KEY_PASSPHRASE=<passphrase for the private key>

# IMIS Server Inventory (imis-mcp)
# Export the server list from the IMIS client as CSV and place it here.
# Default path: ~/.raven/imis-servers.csv (override with IMIS_CSV_PATH)
# IMIS_CSV_PATH=/path/to/your/imis-export.csv

# Email Alerts (SMTP) — used by server-ui for alert notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=25
SMTP_FROM=raven-alerts@example.gov.bc.ca

# Rate limiting (token bucket + circuit breaker per upstream host).
# Defaults are conservative — uncomment only to tune.
# Atlassian APIs: burst 30 / sustained 10 req/sec per host
# RATE_LIMIT_ATLASSIAN_BURST=30
# RATE_LIMIT_ATLASSIAN_RPS=10
# SSH (server-mcp, imis-mcp): burst 5 / sustained 2 req/sec per host
# RATE_LIMIT_SSH_BURST=5
# RATE_LIMIT_SSH_RPS=2
# Circuit breaker (shared by both): trips after N failures within window,
# stays open for cooldown before half-opening for a trial.
# RATE_LIMIT_BREAKER_FAILURES=3
# RATE_LIMIT_BREAKER_WINDOW_S=30
# RATE_LIMIT_BREAKER_COOLDOWN_S=30

# Workaround flagging — set to any non-empty value to have MCP agents append a
# ⚠️ WORKAROUND note when a tool call failed, returned unexpected results, or
# required a multi-step workaround. Useful for developers who want to identify
# fixable limitations; leave unset for regular/non-dev use.
# RAVEN_FLAG_WORKAROUNDS=true

# Azure DevOps Server (ado-mcp)
ADO_BASE_URL=<https://your-ado-server.example.com>
ADO_DEFAULT_COLLECTION=<default collection, e.g. DefaultCollection>
ADO_PAT=<your Personal Access Token>
ADO_DEFAULT_PROJECT=<default team project name>
# ADO_API_VERSION=7.1

# Jenkins (jenkins-mcp)
JENKINS_URL=<https://your-jenkins.example.com/jenkins> # HTTPS is required
# Dedicated credentials are recommended for autonomous runs.
# JENKINS_USER=<your Jenkins username>
# JENKINS_TOKEN=<your Jenkins API token>
# JENKINS_PASSWORD=<your Jenkins password; use only when an API token is unavailable>
# Exact job configs, artifact downloads, and file-sourced secrets are restricted
# to protected directories under ~/.raven by default. Override only if needed.
# RAVEN_JENKINS_CONFIG_DIR=/path/to/protected/jenkins-configs
# RAVEN_JENKINS_DOWNLOAD_DIR=/path/to/protected/jenkins-downloads
# RAVEN_JENKINS_SECRET_DIR=/path/to/protected/jenkins-secrets
