# Global SonarQube Scanner Configuration for RAVEN
# Set default exclusions and configurations below. This file supports
# comments starting with '#' or ';'. Key/Value lines should be in key=value format.
# This can be overwritten for each project repo by adding a sonar.config file to the repo root

# Comma-separated list of file/directory patterns to exclude from analysis
exclusions=**/node_modules/**,**/dist/**,**/__tests__/**,**/*.test.ts,**/wwwroot/lib/**,**/bin/**,**/obj/**,**/Migrations/**

# Patterns to exclude from Duplication / Copy-Paste Detection (CPD)
cpdExclusions=**/*.cshtml

# Patterns to exclude from code coverage reports
coverageExclusions=**/Program.cs
